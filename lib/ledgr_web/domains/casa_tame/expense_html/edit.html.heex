<section class="content">
  <div class="content-body">
    <.link navigate={dp(@domain_path_prefix, "/expenses/#{@expense.id}")} style="text-decoration: none; color: var(--ct-on-surface-variant); font-size: 0.85rem; display: inline-flex; align-items: center; gap: 0.25rem;">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Back to Expense
    </.link>

    <header class="content-header" style="margin-top: 0.5rem;">
      <div>
        <div class="ct-hero-label" style="margin-bottom: 0.15rem;">Financial Atelier</div>
        <h1 class="page-title">Edit Expense</h1>
      </div>
    </header>

    <.form :let={f} for={@changeset} as={:expense} action={@action} method="put">
      <%= if @changeset.action do %>
        <div class="alert alert-error">
          <p>There were problems with your expense. Please review the fields below.</p>
        </div>
      <% end %>

      <div class="ct-form-section-label">Expense Details</div>
      <div class="field">
        <.input field={f[:description]} type="text" label="Description" />
      </div>
      <div class="ct-form-grid-2">
        <div class="field">
          <.input field={f[:date]} type="date" label="Date" />
        </div>
        <div class="field">
          <.input field={f[:payee]} type="text" label="Payee" placeholder="Who are you paying?" />
        </div>
      </div>

      <div class="ct-form-section-label">Categorize</div>
      <div class="ct-form-grid-2">
        <div class="field">
          <.input field={f[:expense_account_id]} type="searchable_select" label="Category" prompt="Search or select category..." options={@expense_account_options} />
        </div>
        <div class="field">
          <.input field={f[:paid_from_account_id]} type="select" label="Paid from" prompt="Select payment account" options={@paid_from_account_options} />
        </div>
      </div>

      <div class="ct-form-section-label">Amount</div>
      <div class="ct-form-amount-card">
        <div class="ct-form-amount-main">
          <.input field={f[:amount_cents]} type="number" min="0" step="0.01" label="Amount" placeholder="0.00" />
        </div>
        <div class="field" style="margin-top: 0.75rem;">
          <.input field={f[:currency]} type="select" label="Currency" options={@currency_options} />
        </div>
      </div>

      <button class="ct-form-save-btn" type="submit">Update Expense</button>
      <.link navigate={dp(@domain_path_prefix, "/expenses/#{@expense.id}")} class="ct-form-cancel">Cancel</.link>
    </.form>

    <div style="margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--ct-outline-variant);">
      <.link href={dp(@domain_path_prefix, "/expenses/#{@expense.id}")} method="delete" data-confirm="Are you sure you want to delete this expense?" style="display: block; text-align: center; font-size: 0.8rem; color: #9e4a4a; text-decoration: none; padding: 0.5rem;">
        Delete this expense
      </.link>
    </div>
  </div>
</section>

<script>
  (function() {
    const currencySelect = document.querySelector('[name="expense[currency]"]');
    const paidFromSelect = document.querySelector('[name="expense[paid_from_account_id]"]');
    if (!currencySelect || !paidFromSelect) return;

    const allOptions = Array.from(paidFromSelect.options).map(opt => ({
      value: opt.value,
      text: opt.text,
      selected: opt.selected
    }));

    function filterPaidFrom() {
      const currency = currencySelect.value;
      const currentValue = paidFromSelect.value;

      paidFromSelect.innerHTML = '';

      const prompt = document.createElement('option');
      prompt.value = '';
      prompt.textContent = 'Select payment account';
      paidFromSelect.appendChild(prompt);

      allOptions.forEach(opt => {
        if (!opt.value) return;
        if (opt.text.startsWith(currency + ':')) {
          const option = document.createElement('option');
          option.value = opt.value;
          option.textContent = opt.text.replace(/^(USD|MXN): /, '');
          if (opt.value === currentValue) option.selected = true;
          paidFromSelect.appendChild(option);
        }
      });
    }

    currencySelect.addEventListener('change', filterPaidFrom);
    filterPaidFrom();
  })();
</script>
