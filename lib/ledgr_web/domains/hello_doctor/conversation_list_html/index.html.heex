<div class="hd-page">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold" style="color: var(--text-main);">Conversations</h1>
  </div>

  <%!-- Filters --%>
  <div class="hd-card p-4 mb-6">
    <form
      method="get"
      action={dp(@domain_path_prefix, "/conversations")}
      class="flex flex-wrap gap-3 items-end"
    >
      <div class="flex-1 min-w-[140px]">
        <label class="block text-xs font-medium mb-1" style="color: var(--text-muted);">
          Status
        </label>
        <select
          name="status"
          class="w-full rounded-md border px-3 py-2 text-sm"
          style="background: var(--bg-surface); border-color: var(--border-subtle); color: var(--text-main);"
        >
          <option value="">All</option>
          <option value="active" selected={@current_status == "active"}>Active</option>
          <option value="closed" selected={@current_status == "closed"}>Closed</option>
        </select>
      </div>
      <div class="flex-1 min-w-[140px]">
        <label class="block text-xs font-medium mb-1" style="color: var(--text-muted);">
          Funnel Stage
        </label>
        <select
          name="funnel_stage"
          class="w-full rounded-md border px-3 py-2 text-sm"
          style="background: var(--bg-surface); border-color: var(--border-subtle); color: var(--text-main);"
        >
          <option value="">All</option>
          <option value="triage" selected={@current_funnel_stage == "triage"}>Triage</option>
          <option
            value="doctor_recommended"
            selected={@current_funnel_stage == "doctor_recommended"}
          >
            Doctor Recommended
          </option>
          <option value="doctor_assigned" selected={@current_funnel_stage == "doctor_assigned"}>
            Doctor Assigned
          </option>
          <option
            value="consultation_active"
            selected={@current_funnel_stage == "consultation_active"}
          >
            Consultation Active
          </option>
          <option value="completed" selected={@current_funnel_stage == "completed"}>
            Completed
          </option>
        </select>
      </div>
      <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-medium mb-1" style="color: var(--text-muted);">
          Search
        </label>
        <input
          type="text"
          name="search"
          value={@current_search}
          placeholder="Patient name or phone..."
          class="w-full rounded-md border px-3 py-2 text-sm"
          style="background: var(--bg-surface); border-color: var(--border-subtle); color: var(--text-main);"
        />
      </div>
      <button type="submit" class="hd-btn-secondary">Filter</button>
    </form>
  </div>

  <%!-- Conversations Table --%>
  <div class="hd-card overflow-hidden">
    <div class="overflow-x-auto">
      <table class="hd-table w-full">
        <thead>
          <tr>
            <th
              class="text-left p-3 text-xs font-medium uppercase"
              style="color: var(--text-muted);"
            >
              Patient
            </th>
            <th
              class="text-left p-3 text-xs font-medium uppercase"
              style="color: var(--text-muted);"
            >
              Status
            </th>
            <th
              class="text-left p-3 text-xs font-medium uppercase"
              style="color: var(--text-muted);"
            >
              Funnel Stage
            </th>
            <th
              class="text-center p-3 text-xs font-medium uppercase"
              style="color: var(--text-muted);"
            >
              Doctor Rec.
            </th>
            <th
              class="text-center p-3 text-xs font-medium uppercase"
              style="color: var(--text-muted);"
            >
              Consultations
            </th>
            <th
              class="text-left p-3 text-xs font-medium uppercase"
              style="color: var(--text-muted);"
            >
              Started
            </th>
            <th
              class="text-left p-3 text-xs font-medium uppercase"
              style="color: var(--text-muted);"
            >
              Last Message
            </th>
            <th
              class="text-right p-3 text-xs font-medium uppercase"
              style="color: var(--text-muted);"
            >
              Actions
            </th>
          </tr>
        </thead>
        <tbody>
          <%= if Enum.empty?(@conversations) do %>
            <tr>
              <td colspan="8" class="p-8 text-center" style="color: var(--text-muted);">
                <div class="text-3xl mb-2 opacity-30">💬</div>
                No conversations found.
              </td>
            </tr>
          <% else %>
            <%= for conv <- @conversations do %>
              <tr
                class="border-t cursor-pointer hover:bg-[rgba(2,186,151,0.04)]"
                style="border-color: var(--border-subtle);"
                onclick={"window.location='#{dp(@domain_path_prefix, "/conversations/#{conv.id}")}';"}
              >
                <td class="p-3">
                  <div class="text-sm font-medium" style="color: var(--text-main);">
                    {if conv.patient,
                      do: conv.patient.full_name || conv.patient.display_name || "Unknown",
                      else: "Unknown"}
                  </div>
                  <div class="text-xs" style="color: var(--text-muted);">
                    {if conv.patient, do: conv.patient.phone, else: ""}
                  </div>
                </td>
                <td class="p-3">
                  <% status_badge =
                    case conv.status do
                      "active" -> "in_progress"
                      "closed" -> "completed"
                      _ -> "pending"
                    end %>
                  <span class={"hd-badge hd-badge--#{status_badge}"}>
                    {conv.status |> to_string() |> String.capitalize()}
                  </span>
                </td>
                <td class="p-3">
                  <span class="text-sm" style="color: var(--text-main);">
                    {conv.funnel_stage
                    |> to_string()
                    |> String.replace("_", " ")
                    |> String.capitalize()}
                  </span>
                </td>
                <td class="p-3 text-center">
                  <%= if conv.doctor_recommended do %>
                    <span style="color: #02ba97;">✓</span>
                  <% else %>
                    <span style="color: var(--text-muted);">—</span>
                  <% end %>
                </td>
                <td class="p-3 text-center">
                  <span class="text-sm font-medium" style="color: var(--text-main);">
                    {length(conv.consultations)}
                  </span>
                </td>
                <td class="p-3 text-sm" style="color: var(--text-muted);">
                  {fmt_datetime(conv.created_at) || "---"}
                </td>
                <td class="p-3 text-sm" style="color: var(--text-muted);">
                  {fmt_datetime(conv.last_message_at, "%b %d, %I:%M %p") || "---"}
                </td>
                <td class="p-3 text-right">
                  <.link
                    navigate={dp(@domain_path_prefix, "/conversations/#{conv.id}")}
                    class="text-sm font-medium"
                    style="color: var(--accent);"
                  >
                    View
                  </.link>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
