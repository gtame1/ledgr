<% conv = @conversation %>
<% mr = conv.medical_record %>
<% messages = conv.messages || [] %>

<div class="hd-page">
  <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
    <.link
      navigate={dp(@domain_path_prefix, "/conversations") <> (assigns[:filter_qs] || "")}
      class="hd-back"
    >
      &larr; Back to Conversations
    </.link>

    <div class="flex items-center gap-2">
      <%= if assigns[:prev_id] do %>
        <.link
          navigate={
            dp(@domain_path_prefix, "/conversations/#{@prev_id}") <> (assigns[:filter_qs] || "")
          }
          class="hd-btn-secondary"
          title="Previous conversation (more recent)"
        >
          &larr; Previous
        </.link>
      <% else %>
        <span
          class="hd-btn-secondary opacity-40 cursor-not-allowed"
          aria-disabled="true"
          title="No more recent conversation in the filtered list"
        >
          &larr; Previous
        </span>
      <% end %>
      <%= if assigns[:next_id] do %>
        <.link
          navigate={
            dp(@domain_path_prefix, "/conversations/#{@next_id}") <> (assigns[:filter_qs] || "")
          }
          class="hd-btn-secondary"
          title="Next conversation (older)"
        >
          Next &rarr;
        </.link>
      <% else %>
        <span
          class="hd-btn-secondary opacity-40 cursor-not-allowed"
          aria-disabled="true"
          title="No older conversation in the filtered list"
        >
          Next &rarr;
        </span>
      <% end %>
    </div>
  </div>

  <%!-- Header --%>
  <div class="flex items-center gap-3 mb-6">
    <h1 class="text-2xl font-bold" style="color: var(--text-main);">Conversation</h1>
    <% status_badge =
      case conv.status do
        "active" -> "in_progress"
        "closed" -> "completed"
        _ -> "pending"
      end %>
    <span class={"hd-badge hd-badge--#{status_badge}"}>
      {conv.status |> to_string() |> String.capitalize()}
    </span>
    <span class="text-sm" style="color: var(--text-muted);">
      {conv.funnel_stage |> to_string() |> String.replace("_", " ") |> String.capitalize()}
    </span>
    <%= cond do %>
      <% conv.tenant in [nil, ""] -> %>
      <% conv.tenant == "direct" -> %>
        <span
          class="hd-badge"
          style="background: #ede9fe; color: #5b21b6;"
          title="Patient picked a specific doctor; uses that doctor's consultation_fee_mxn."
        >
          direct
        </span>
      <% true -> %>
        <span
          class="hd-badge"
          style="background: var(--bg-secondary); color: var(--text-muted);"
          title={"Bot-side flow: " <> conv.tenant}
        >
          {conv.tenant}
        </span>
    <% end %>
  </div>

  <div class="hd-two-col">
    <%!-- Left Column --%>
    <div class="space-y-6">
      <%!-- AI Summary --%>
      <%= if mr && mr.ai_summary do %>
        <div class="hd-card p-5" style="border-left: 4px solid #02ba97;">
          <h2 class="text-sm font-semibold uppercase mb-2" style="color: var(--accent);">
            AI Summary
          </h2>
          <div
            class="text-sm leading-relaxed whitespace-pre-line"
            style="color: var(--text-main);"
          >
            {mr.ai_summary}
          </div>
        </div>
      <% end %>

      <%!-- Chief Complaint & Triage --%>
      <%= if mr && (mr.chief_complaint || mr.urgency || mr.possible_conditions) do %>
        <div class="hd-card p-5">
          <h2 class="text-sm font-semibold uppercase mb-3" style="color: var(--text-muted);">
            Triage Assessment
          </h2>
          <div class="grid grid-cols-2 gap-4">
            <%= if mr.chief_complaint do %>
              <div class="col-span-2">
                <div class="text-xs uppercase font-medium mb-1" style="color: var(--text-muted);">
                  Chief Complaint
                </div>
                <div class="text-sm font-medium" style="color: var(--text-main);">
                  {mr.chief_complaint}
                </div>
              </div>
            <% end %>
            <%= if mr.urgency do %>
              <div>
                <div class="text-xs uppercase font-medium mb-1" style="color: var(--text-muted);">
                  Urgency
                </div>
                <div class="text-sm" style="color: var(--text-main);">
                  {mr.urgency |> String.capitalize()}
                </div>
              </div>
            <% end %>
            <%= if mr.specialty do %>
              <div>
                <div class="text-xs uppercase font-medium mb-1" style="color: var(--text-muted);">
                  Specialty
                </div>
                <div class="text-sm" style="color: var(--text-main);">{mr.specialty}</div>
              </div>
            <% end %>
            <%= if mr.possible_conditions do %>
              <div class="col-span-2">
                <div class="text-xs uppercase font-medium mb-1" style="color: var(--text-muted);">
                  Possible Conditions
                </div>
                <div class="text-sm" style="color: var(--text-main);">
                  <.possible_conditions value={mr.possible_conditions} />
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <%!-- Messages --%>
      <%= if messages != [] do %>
        <div class="hd-card p-5">
          <h2 class="text-sm font-semibold uppercase mb-3" style="color: var(--text-muted);">
            Messages
            <span class="text-xs font-normal ml-1" style="color: var(--text-muted);">
              ({length(messages)})
            </span>
          </h2>
          <div class="space-y-3 max-h-[600px] overflow-y-auto">
            <%= for msg <- Enum.sort_by(messages, & &1.created_at, NaiveDateTime) do %>
              <% is_patient = msg.role in ["user", "patient"] %>
              <% is_doctor = msg.role in ["doctor"] %>
              <% is_ai = not is_patient and not is_doctor %>
              <% msg_bg =
                cond do
                  is_patient -> "bg-[#d0f5ed]"
                  is_doctor -> "bg-[#dbeafe]"
                  true -> "bg-[#f1f5f9]"
                end

              msg_color =
                cond do
                  is_patient -> "#065f46"
                  is_doctor -> "#1e40af"
                  true -> "#64748b"
                end %>
              <div class={"flex #{if is_patient, do: "justify-end", else: "justify-start"}"}>
                <div class={"max-w-[80%] rounded-lg p-3 text-sm #{msg_bg}"}>
                  <div class="text-xs font-semibold mb-1" style={"color: #{msg_color};"}>
                    {cond do
                      is_patient -> "Patient"
                      is_doctor -> "Doctor"
                      true -> "HelloDoctor AI"
                    end}
                  </div>
                  <div class="whitespace-pre-line" style="color: var(--text-main);">
                    {msg.content}
                  </div>
                  <div class="flex items-center justify-between gap-2 mt-1">
                    <%= if msg.created_at do %>
                      <div class="text-xs opacity-60">{fmt_time(msg.created_at)}</div>
                    <% else %>
                      <div></div>
                    <% end %>
                    <%= if is_ai do %>
                      <%!-- Feedback anchors (bot ADR-059): fill the hidden
                           fields in the Quality Feedback form below. --%>
                      <div class="text-xs" style="white-space: nowrap;">
                        <%= if conv.first_bad_message_id == msg.id do %>
                          <span
                            title="Currently marked as the first bad message"
                            style="background: #fee2e2; color: #991b1b; padding: 0 0.3rem; border-radius: 0.25rem; font-weight: 600;"
                          >
                            ⚑ first bad
                          </span>
                        <% end %>
                        <%= if conv.exemplary_message_id == msg.id do %>
                          <span
                            title="Currently marked as an exemplary message"
                            style="background: #d1fae5; color: #065f46; padding: 0 0.3rem; border-radius: 0.25rem; font-weight: 600;"
                          >
                            ★ exemplary
                          </span>
                        <% end %>
                        <button
                          type="button"
                          onclick={"hdAnchor('first_bad_message_id', '#{msg.id}', this)"}
                          title="Anchor: first bad message (fills the feedback form)"
                          class="hd-anchor-btn hd-anchor-btn--bad"
                          style="border: none; background: transparent; cursor: pointer; opacity: 0.45; padding: 0 0.15rem;"
                        >
                          ⚑
                        </button>
                        <button
                          type="button"
                          onclick={"hdAnchor('exemplary_message_id', '#{msg.id}', this)"}
                          title="Anchor: exemplary message (fills the feedback form)"
                          class="hd-anchor-btn hd-anchor-btn--good"
                          style="border: none; background: transparent; cursor: pointer; opacity: 0.45; padding: 0 0.15rem;"
                        >
                          ★
                        </button>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="hd-card p-5">
          <div class="hd-empty">
            <div class="hd-empty-icon">💬</div>
            <p>No messages in this conversation</p>
          </div>
        </div>
      <% end %>
    </div>

    <%!-- Right Column --%>
    <div class="space-y-6">
      <%!-- Quality Feedback (writes to the bot via its admin API — bot ADR-059) --%>
      <% signal_now = conv.quality_signal %>
      <div class="hd-card p-5" style="border-left: 4px solid #f59e0b;">
        <h3 class="text-sm font-semibold uppercase mb-1" style="color: var(--text-muted);">
          Quality Feedback
        </h3>
        <%= if signal_now do %>
          <div class="text-xs mb-3" style="color: var(--text-muted);">
            Marked
            <strong style={"color: #{if signal_now == "good", do: "#065f46", else: "#991b1b"};"}>
              {signal_now}
            </strong>
            <%= if conv.failure_category do %>
              · {Ledgr.Domains.HelloDoctor.ConversationFeedback.category_label(
                conv.failure_category
              )}
            <% end %>
            <%= if conv.quality_marked_by do %>
              · by {conv.quality_marked_by}
            <% end %>
            <%= if conv.quality_marked_at do %>
              · {Calendar.strftime(conv.quality_marked_at, "%Y-%m-%d %H:%M")} UTC
            <% end %>
          </div>
        <% else %>
          <div class="text-xs mb-3" style="color: var(--text-muted);">
            Unreviewed. A <strong>bad</strong>
            mark needs a category + rationale; use ⚑ / ★ next to an AI message to anchor it.
          </div>
        <% end %>

        <form
          id="hd-feedback-form"
          action={dp(@domain_path_prefix, "/conversations/#{conv.id}/feedback")}
          method="post"
          class="space-y-3"
        >
          <input type="hidden" name="_csrf_token" value={Phoenix.Controller.get_csrf_token()} />
          <%= for {k, v} <- @filters, v not in [nil, ""] do %>
            <input type="hidden" name={k} value={v} />
          <% end %>
          <input
            type="hidden"
            id="hd-first_bad_message_id"
            name="first_bad_message_id"
            value={conv.first_bad_message_id || ""}
          />
          <input
            type="hidden"
            id="hd-exemplary_message_id"
            name="exemplary_message_id"
            value={conv.exemplary_message_id || ""}
          />

          <div class="flex items-center gap-3">
            <label
              class="text-sm flex items-center gap-1"
              style="color: #065f46; font-weight: 600; cursor: pointer;"
            >
              <input
                type="radio"
                name="signal"
                value="good"
                checked={signal_now == "good"}
                onchange="hdSignalChanged()"
              /> ✓ Good
            </label>
            <label
              class="text-sm flex items-center gap-1"
              style="color: #991b1b; font-weight: 600; cursor: pointer;"
            >
              <input
                type="radio"
                name="signal"
                value="bad"
                checked={signal_now == "bad"}
                onchange="hdSignalChanged()"
              /> ✗ Bad
            </label>
            <label
              class="text-xs flex items-center gap-1 ml-auto"
              style="color: var(--text-muted); cursor: pointer;"
              title="Flag for the persona/few-shot harvest corpus"
            >
              <input
                type="checkbox"
                name="corpus_candidate"
                value="true"
                checked={conv.corpus_candidate == true}
              /> 📚 Corpus
            </label>
          </div>

          <div id="hd-bad-only" style="display: none;" class="space-y-3">
            <div>
              <label class="text-xs uppercase font-medium" style="color: var(--text-muted);">
                Failure category
              </label>
              <select id="hd-category" name="failure_category" class="hd-input text-sm w-full">
                <option value="">— pick one —</option>
                <%= for {value, label} <- @feedback_categories do %>
                  <option value={value} selected={conv.failure_category == value}>{label}</option>
                <% end %>
              </select>
            </div>
            <div>
              <label class="text-xs uppercase font-medium" style="color: var(--text-muted);">
                What should the bot have said?
                <span style="text-transform: none; font-weight: 400;">(optional, gold)</span>
              </label>
              <textarea
                name="corrected_response"
                rows="3"
                maxlength="4000"
                class="hd-input text-sm w-full"
                placeholder="The reply Nura should have given — becomes eval/few-shot material."
              >{conv.corrected_response || ""}</textarea>
            </div>
          </div>

          <div>
            <label class="text-xs uppercase font-medium" style="color: var(--text-muted);">
              Rationale
              <span id="hd-notes-req" style="text-transform: none; font-weight: 400;"></span>
            </label>
            <textarea
              id="hd-notes"
              name="notes"
              rows="2"
              class="hd-input text-sm w-full"
              placeholder="One line: why is this good/bad?"
            >{conv.quality_notes || ""}</textarea>
          </div>

          <div class="flex items-center gap-2">
            <input
              type="text"
              name="marked_by"
              value={@marker}
              placeholder="your handle"
              class="hd-input text-sm"
              style="width: 8rem;"
              title="Saved to session; sent as marked_by."
            />
            <button type="submit" class="hd-btn-sm" style="margin-left: auto;">
              Save feedback
            </button>
          </div>
        </form>
      </div>

      <%!-- Live operator case note (bot ADR-059: injected into the bot's context) --%>
      <% has_note = (conv.operator_notes || "") != "" %>
      <div
        class="hd-card p-5"
        style={"border-left: 4px solid #{if has_note, do: "#8b5cf6", else: "var(--border-subtle)"};"}
      >
        <div class="flex items-center gap-2 mb-1">
          <h3 class="text-sm font-semibold uppercase" style="color: var(--text-muted);">
            Case Note → Bot
          </h3>
          <%= if has_note do %>
            <span
              style="background: #ede9fe; color: #5b21b6; padding: 0.1rem 0.45rem; border-radius: 0.25rem; font-size: 0.7rem; font-weight: 600;"
              title="The bot injects this note into its context on every turn of this conversation."
            >
              ● live
            </span>
          <% end %>
        </div>
        <div class="text-xs mb-3" style="color: var(--text-muted);">
          Injected into the bot's context on its next turn — case facts and steering for
          <em>this</em>
          conversation only (e.g. "ya envió sus estudios; no se los vuelvas a pedir").
          It can't override safety rules. Clear it when it no longer applies.
          <%= if has_note and conv.operator_notes_updated_by do %>
            <div class="mt-1">
              Last set by {conv.operator_notes_updated_by}
              <%= if conv.operator_notes_updated_at do %>
                · {Calendar.strftime(conv.operator_notes_updated_at, "%Y-%m-%d %H:%M")} UTC
              <% end %>
            </div>
          <% end %>
        </div>

        <form
          action={dp(@domain_path_prefix, "/conversations/#{conv.id}/operator-notes")}
          method="post"
          class="space-y-2"
        >
          <input type="hidden" name="_csrf_token" value={Phoenix.Controller.get_csrf_token()} />
          <%= for {k, v} <- @filters, v not in [nil, ""] do %>
            <input type="hidden" name={k} value={v} />
          <% end %>
          <textarea
            id="hd-op-notes"
            name="operator_notes"
            rows="3"
            maxlength="1500"
            class="hd-input text-sm w-full"
            placeholder="Nota para el bot sobre este caso (máx. 1500)."
          >{conv.operator_notes || ""}</textarea>
          <div class="flex items-center gap-2">
            <input
              type="text"
              name="updated_by"
              value={@marker}
              placeholder="your handle"
              class="hd-input text-sm"
              style="width: 8rem;"
            />
            <%= if has_note do %>
              <button
                type="submit"
                class="hd-btn-sm"
                style="background: #fee2e2; color: #991b1b;"
                onclick="document.getElementById('hd-op-notes').value = '';"
                title="Remove the note — the bot stops seeing it immediately."
              >
                Clear
              </button>
            <% end %>
            <button type="submit" class="hd-btn-sm" style="margin-left: auto;">
              Save note
            </button>
          </div>
        </form>
      </div>

      <%!-- Patient --%>
      <%= if conv.patient do %>
        <div class="hd-card p-5">
          <h3 class="text-sm font-semibold uppercase mb-3" style="color: var(--text-muted);">
            Patient
          </h3>
          <div class="flex items-center gap-3 mb-3">
            <div
              class="w-10 h-10 rounded-full flex items-center justify-center text-white text-sm font-bold"
              style="background: var(--primary);"
            >
              {String.first(conv.patient.full_name || conv.patient.display_name || "?")}
            </div>
            <div>
              <.link
                navigate={dp(@domain_path_prefix, "/patients/#{conv.patient.id}")}
                class="text-sm font-medium"
                style="color: var(--accent);"
              >
                {conv.patient.full_name || conv.patient.display_name || "Unknown"}
              </.link>
              <div class="text-xs" style="color: var(--text-muted);">
                {conv.patient.phone || ""}
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <%!-- Conversation Details --%>
      <div class="hd-card p-5">
        <h3 class="text-sm font-semibold uppercase mb-3" style="color: var(--text-muted);">
          Details
        </h3>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between">
            <span style="color: var(--text-muted);">Status</span>
            <span style="color: var(--text-main);">
              {conv.status |> to_string() |> String.capitalize()}
            </span>
          </div>
          <div class="flex justify-between">
            <span style="color: var(--text-muted);">Funnel Stage</span>
            <span style="color: var(--text-main);">
              {conv.funnel_stage |> to_string() |> String.replace("_", " ") |> String.capitalize()}
            </span>
          </div>
          <div class="flex justify-between">
            <span
              style="color: var(--text-muted);"
              title="Bot-side flow: 'mvp' = on-demand routing, 'direct' = patient picked the doctor."
            >
              Tenant
            </span>
            <span style="color: var(--text-main);">
              {conv.tenant || "—"}
            </span>
          </div>
          <div class="flex justify-between">
            <span
              style="color: var(--text-muted);"
              title="ADR-046: stripe = patient-paid, corporate = employer-paid, test = /prueba bypass."
            >
              Payment source
            </span>
            <span style="color: var(--text-main);">
              {conv.payment_source || "stripe"}
              <%= if conv.corporate_account_id do %>
                <span style="color: var(--text-muted); font-size: 0.75rem;">
                  · {conv.corporate_account_id}
                </span>
              <% end %>
            </span>
          </div>
          <div class="flex justify-between">
            <span style="color: var(--text-muted);">Doctor Recommended</span>
            <span style="color: var(--text-main);">
              {if conv.doctor_recommended, do: "Yes", else: "No"}
            </span>
          </div>
          <%= if conv.doctor_declined_by_patient do %>
            <div class="flex justify-between">
              <span style="color: var(--text-muted);">Patient Declined Doctor</span>
              <span style="color: #dc2626;">Yes</span>
            </div>
          <% end %>
          <%= if conv.resolved_without_doctor do %>
            <div class="flex justify-between">
              <span style="color: var(--text-muted);">Resolved w/o Doctor</span>
              <span style="color: var(--accent);">Yes</span>
            </div>
          <% end %>
          <div class="flex justify-between">
            <span style="color: var(--text-muted);">Started</span>
            <span style="color: var(--text-main);">{fmt_datetime(conv.created_at) || "---"}</span>
          </div>
          <div class="flex justify-between">
            <span style="color: var(--text-muted);">Last Message</span>
            <span style="color: var(--text-main);">
              {fmt_datetime(conv.last_message_at) || "---"}
            </span>
          </div>
        </div>
      </div>

      <%!-- Linked Consultations --%>
      <div class="hd-card p-5">
        <h3 class="text-sm font-semibold uppercase mb-3" style="color: var(--text-muted);">
          Consultations
        </h3>
        <%= if Enum.empty?(conv.consultations) do %>
          <div class="text-sm" style="color: var(--text-muted);">
            No consultations created from this conversation.
          </div>
        <% else %>
          <div class="space-y-2">
            <%= for c <- conv.consultations do %>
              <.link
                navigate={dp(@domain_path_prefix, "/consultations/#{c.id}")}
                class="block p-3 rounded-lg hover:bg-[rgba(2,186,151,0.04)] no-underline"
                style="border: 1px solid var(--border-subtle);"
              >
                <div class="flex items-center justify-between">
                  <span class={"hd-badge hd-badge--#{c.status}"}>
                    {c.status |> to_string() |> String.replace("_", " ") |> String.capitalize()}
                  </span>
                  <span class="text-xs" style="color: var(--text-muted);">
                    {fmt_date(c.assigned_at) || "---"}
                  </span>
                </div>
                <%= if c.payment_status do %>
                  <div class="text-xs mt-1" style="color: var(--text-muted);">
                    Payment: {c.payment_status |> String.capitalize()}
                    {if c.payment_amount,
                      do: " — $#{:erlang.float_to_binary(c.payment_amount, decimals: 2)}",
                      else: ""}
                  </div>
                <% end %>
              </.link>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  // Feedback-panel helpers (bot ADR-059). Plain JS — this is a dead view.
  function hdSignalChanged() {
    const bad = document.querySelector('input[name="signal"][value="bad"]').checked;
    document.getElementById("hd-bad-only").style.display = bad ? "" : "none";
    document.getElementById("hd-category").required = bad;
    document.getElementById("hd-notes").required = bad;
    document.getElementById("hd-notes-req").textContent = bad ? "(required)" : "";
  }

  // Toggle an anchor: click fills the hidden field; clicking the same
  // message again clears it. Active buttons render at full opacity.
  function hdAnchor(field, msgId, btn) {
    const input = document.getElementById("hd-" + field);
    const cls = field === "first_bad_message_id" ? "hd-anchor-btn--bad" : "hd-anchor-btn--good";
    input.value = input.value === msgId ? "" : msgId;
    document.querySelectorAll("." + cls).forEach((b) => (b.style.opacity = "0.45"));
    if (input.value !== "") btn.style.opacity = "1";
    // Anchoring implies a verdict — preselect the matching signal if unset.
    const signal = field === "first_bad_message_id" ? "bad" : "good";
    if (!document.querySelector('input[name="signal"]:checked')) {
      document.querySelector('input[name="signal"][value="' + signal + '"]').checked = true;
    }
    hdSignalChanged();
  }

  hdSignalChanged();
</script>
