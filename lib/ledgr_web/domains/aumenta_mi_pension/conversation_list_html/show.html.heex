<% conv = @conversation %>
<% pension_case = conv.pension_case %>
<% messages = conv.messages || [] %>

<div class="hd-page">
  <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
    <.link
      navigate={dp(@domain_path_prefix, "/conversations") <> @filter_qs}
      class="hd-back"
    >
      &larr; Volver a Conversaciones
    </.link>

    <div class="flex items-center gap-2">
      <%= if @prev_id do %>
        <.link
          navigate={dp(@domain_path_prefix, "/conversations/#{@prev_id}") <> @filter_qs}
          class="hd-btn-secondary"
          title="Conversación anterior (más reciente)"
        >
          &larr; Anterior
        </.link>
      <% else %>
        <span
          class="hd-btn-secondary opacity-40 cursor-not-allowed"
          aria-disabled="true"
          title="No hay conversación más reciente en la lista filtrada"
        >
          &larr; Anterior
        </span>
      <% end %>
      <%= if @next_id do %>
        <.link
          navigate={dp(@domain_path_prefix, "/conversations/#{@next_id}") <> @filter_qs}
          class="hd-btn-secondary"
          title="Conversación siguiente (más antigua)"
        >
          Siguiente &rarr;
        </.link>
      <% else %>
        <span
          class="hd-btn-secondary opacity-40 cursor-not-allowed"
          aria-disabled="true"
          title="No hay conversación más antigua en la lista filtrada"
        >
          Siguiente &rarr;
        </span>
      <% end %>
    </div>
  </div>

  <%!-- Header --%>
  <div class="flex items-center gap-3 mb-6">
    <h1 class="text-2xl font-bold" style="color: var(--text-main);">Conversación</h1>
    <% status_badge =
      case conv.status do
        "active" -> "in_progress"
        "closed" -> "completed"
        _ -> "pending"
      end %>
    <span class={"hd-badge hd-badge--#{status_badge}"}>
      {conv.status |> to_string() |> String.capitalize()}
    </span>
    <span class="text-sm" style="color: var(--text-muted);">
      {funnel_stage_label(conv.funnel_stage)}
    </span>
  </div>

  <div class="hd-two-col">
    <%!-- Left Column --%>
    <div class="space-y-6">
      <%!-- Pension Case summary --%>
      <%= if pension_case do %>
        <div class="hd-card p-5" style="border-left: 4px solid var(--accent);">
          <h2 class="text-sm font-semibold uppercase mb-2" style="color: var(--accent);">
            Caso de Pensión
          </h2>
          <%= if pension_case.ai_summary do %>
            <div
              class="text-sm leading-relaxed whitespace-pre-line mb-3"
              style="color: var(--text-main);"
            >
              {pension_case.ai_summary}
            </div>
          <% end %>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <div class="text-xs uppercase" style="color: var(--text-muted);">
                Modalidad Recomendada
              </div>
              <div class="text-sm font-medium" style="color: var(--text-main);">
                {pension_case.recommended_modalidad || "---"}
              </div>
            </div>
            <div>
              <div class="text-xs uppercase" style="color: var(--text-muted);">Califica</div>
              <div class="text-sm font-medium" style="color: var(--text-main);">
                {cond do
                  pension_case.qualifies == true -> "Sí"
                  pension_case.qualifies == false -> "No"
                  true -> "---"
                end}
              </div>
            </div>
          </div>
          <div class="mt-3">
            <.link
              navigate={dp(@domain_path_prefix, "/pension-cases/#{pension_case.id}")}
              class="text-sm font-medium"
              style="color: var(--accent);"
            >
              Ver caso completo →
            </.link>
          </div>
        </div>
      <% end %>

      <%!-- Messages --%>
      <%= if messages != [] do %>
        <div class="hd-card p-5">
          <h2 class="text-sm font-semibold uppercase mb-3" style="color: var(--text-muted);">
            Mensajes
            <span class="text-xs font-normal ml-1" style="color: var(--text-muted);">
              ({length(messages)})
            </span>
          </h2>
          <div class="space-y-3 max-h-[600px] overflow-y-auto">
            <%= for msg <- Enum.sort_by(messages, & &1.created_at) do %>
              <% is_customer = msg.role in ["user", "customer"] %>
              <% is_agent = msg.role in ["agent"] %>
              <% msg_bg =
                cond do
                  is_customer -> "bg-[#dbe5f5]"
                  is_agent -> "bg-[#fff2c6]"
                  true -> "bg-[#f1f5f9]"
                end

              msg_color =
                cond do
                  is_customer -> "#1f3b6a"
                  is_agent -> "#8a6d00"
                  true -> "#64748b"
                end %>
              <div class={"flex #{if is_customer, do: "justify-end", else: "justify-start"}"}>
                <div class={"max-w-[80%] rounded-lg p-3 text-sm #{msg_bg}"}>
                  <div class="text-xs font-semibold mb-1" style={"color: #{msg_color};"}>
                    {cond do
                      is_customer -> "Cliente"
                      is_agent -> "Agente"
                      true -> "Aumenta Mi Pensión AI"
                    end}
                  </div>
                  <div class="whitespace-pre-line" style="color: var(--text-main);">
                    {msg.content}
                  </div>
                  <%= if msg.created_at do %>
                    <div class="text-xs mt-1 opacity-60">{fmt_time(msg.created_at)}</div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="hd-card p-5">
          <div class="hd-empty">
            <p>Sin mensajes en esta conversación</p>
          </div>
        </div>
      <% end %>
    </div>

    <%!-- Right Column --%>
    <div class="space-y-6">
      <%!-- Customer --%>
      <%= if conv.customer do %>
        <div class="hd-card p-5">
          <h3 class="text-sm font-semibold uppercase mb-3" style="color: var(--text-muted);">
            Cliente
          </h3>
          <div class="flex items-center gap-3 mb-3">
            <div
              class="w-10 h-10 rounded-full flex items-center justify-center text-white text-sm font-bold"
              style="background: var(--primary);"
            >
              {String.first(conv.customer.full_name || conv.customer.display_name || "?")}
            </div>
            <div>
              <.link
                navigate={dp(@domain_path_prefix, "/customers/#{conv.customer.id}")}
                class="text-sm font-medium"
                style="color: var(--accent);"
              >
                {conv.customer.full_name || conv.customer.display_name || "Desconocido"}
              </.link>
              <div class="text-xs" style="color: var(--text-muted);">
                {conv.customer.phone || ""}
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <%!--
        CRM pipeline — operator's traditional contact/sales funnel.
        Independent of the four-axis state model below; both groups
        live on the same `conversation_crm` row but track different
        concerns.
      --%>
      <div class="hd-card p-5">
        <h3 class="text-sm font-semibold uppercase mb-3" style="color: var(--text-muted);">
          CRM
        </h3>
        <.form
          for={%{}}
          action={dp(@domain_path_prefix, "/conversations/#{conv.id}/crm")}
          method="post"
          class="space-y-3"
        >
          <input
            type="hidden"
            name="_filters"
            value={String.replace_prefix(@filter_qs, "?", "")}
          />

          <div>
            <label
              for="conv_crm_contact_stage"
              class="block text-xs font-medium mb-1"
              style="color: var(--text-muted);"
            >
              Etapa de Contacto
            </label>
            <select
              id="conv_crm_contact_stage"
              name="contact_stage"
              onchange="this.form.submit()"
              class="w-full rounded-md border px-3 py-2 text-sm"
              style="background: var(--bg-surface); border-color: var(--border-subtle); color: var(--text-main);"
            >
              <option value="" selected={is_nil(@crm_entry.contact_stage)}>
                — sin definir —
              </option>
              <%= for {label, value} <- @crm_contact_stage_options do %>
                <option value={value} selected={@crm_entry.contact_stage == value}>
                  {label}
                </option>
              <% end %>
            </select>
          </div>

          <div>
            <label
              for="conv_crm_sales_stage"
              class="block text-xs font-medium mb-1"
              style="color: var(--text-muted);"
            >
              Etapa de Venta
            </label>
            <select
              id="conv_crm_sales_stage"
              name="sales_stage"
              onchange="this.form.submit()"
              class="w-full rounded-md border px-3 py-2 text-sm"
              style="background: var(--bg-surface); border-color: var(--border-subtle); color: var(--text-main);"
            >
              <option value="" selected={is_nil(@crm_entry.sales_stage)}>
                — sin definir —
              </option>
              <%= for {label, value} <- @crm_sales_stage_options do %>
                <option value={value} selected={@crm_entry.sales_stage == value}>
                  {label}
                </option>
              <% end %>
            </select>
          </div>

          <p class="text-xs" style="color: var(--text-muted);">
            Se guarda automáticamente al cambiar.
          </p>
        </.form>
      </div>

      <%!--
        Four-axis state model. The bot is the canonical writer (it
        writes to conversations.qualification_verdict / escalation_status /
        engagement_health, and is migrating conversations.funnel_stage to
        the new vocabulary). The operator can override any axis via the
        `conversation_crm` overlay; the override wins on display.

        UX:
          * Select edits the OVERLAY value.
          * Caption below each select shows the bot's current value.
          * A yellow "Anulado por operador" badge appears when the
            overlay is set.
          * Selecting "— usar valor del bot —" clears the overlay
            (POSTs empty string, which the changeset normalizes to nil),
            revealing the bot's value again.
      --%>
      <div class="hd-card p-5">
        <h3 class="text-sm font-semibold uppercase mb-3" style="color: var(--text-muted);">
          Estado de la Conversación
        </h3>
        <.form
          for={%{}}
          action={dp(@domain_path_prefix, "/conversations/#{conv.id}/crm")}
          method="post"
          class="space-y-3"
        >
          <input
            type="hidden"
            name="_filters"
            value={String.replace_prefix(@filter_qs, "?", "")}
          />

          <%!-- Axis 1: funnel_stage (lifecycle position) --%>
          <div>
            <label
              for="conv_crm_funnel_stage"
              class="block text-xs font-medium mb-1"
              style="color: var(--text-muted);"
            >
              Etapa del Funnel
            </label>
            <select
              id="conv_crm_funnel_stage"
              name="funnel_stage"
              onchange="this.form.submit()"
              class="w-full rounded-md border px-3 py-2 text-sm"
              style={"background: var(--bg-surface); border-color: #{if @crm_entry.funnel_stage, do: "#f59e0b", else: "var(--border-subtle)"}; color: var(--text-main);"}
            >
              <option value="" selected={is_nil(@crm_entry.funnel_stage)}>
                — usar valor del bot —
              </option>
              <%= for {label, value} <- @crm_funnel_stage_options do %>
                <option value={value} selected={@crm_entry.funnel_stage == value}>
                  {label}
                </option>
              <% end %>
            </select>
            <p class="text-xs mt-1" style="color: var(--text-muted);">
              Bot: <span style="color: var(--text-main);">{funnel_stage_label(conv.funnel_stage)}</span>
              <%= if @crm_entry.funnel_stage do %>
                <span
                  class="ml-2 px-2 py-0.5 rounded text-[10px] font-semibold"
                  style="background: #fef3c7; color: #92400e;"
                >
                  Anulado por operador
                </span>
              <% end %>
            </p>
          </div>

          <%!-- Axis 2: qualification_verdict (diagnostic outcome) --%>
          <div>
            <label
              for="conv_crm_qualification_verdict"
              class="block text-xs font-medium mb-1"
              style="color: var(--text-muted);"
            >
              Veredicto de Calificación
            </label>
            <select
              id="conv_crm_qualification_verdict"
              name="qualification_verdict"
              onchange="this.form.submit()"
              class="w-full rounded-md border px-3 py-2 text-sm"
              style={"background: var(--bg-surface); border-color: #{if @crm_entry.qualification_verdict, do: "#f59e0b", else: "var(--border-subtle)"}; color: var(--text-main);"}
            >
              <option value="" selected={is_nil(@crm_entry.qualification_verdict)}>
                — usar valor del bot —
              </option>
              <%= for {label, value} <- @crm_qualification_verdict_options do %>
                <option value={value} selected={@crm_entry.qualification_verdict == value}>
                  {label}
                </option>
              <% end %>
            </select>
            <p class="text-xs mt-1" style="color: var(--text-muted);">
              Bot: <span style="color: var(--text-main);">{qualification_verdict_label(conv.qualification_verdict) || "—"}</span>
              <%= if @crm_entry.qualification_verdict do %>
                <span
                  class="ml-2 px-2 py-0.5 rounded text-[10px] font-semibold"
                  style="background: #fef3c7; color: #92400e;"
                >
                  Anulado por operador
                </span>
              <% end %>
            </p>
          </div>

          <%!-- Axis 3: escalation_status (live-agent track) --%>
          <div>
            <label
              for="conv_crm_escalation_status"
              class="block text-xs font-medium mb-1"
              style="color: var(--text-muted);"
            >
              Estado de Escalación
            </label>
            <select
              id="conv_crm_escalation_status"
              name="escalation_status"
              onchange="this.form.submit()"
              class="w-full rounded-md border px-3 py-2 text-sm"
              style={"background: var(--bg-surface); border-color: #{if @crm_entry.escalation_status, do: "#f59e0b", else: "var(--border-subtle)"}; color: var(--text-main);"}
            >
              <option value="" selected={is_nil(@crm_entry.escalation_status)}>
                — usar valor del bot —
              </option>
              <%= for {label, value} <- @crm_escalation_status_options do %>
                <option value={value} selected={@crm_entry.escalation_status == value}>
                  {label}
                </option>
              <% end %>
            </select>
            <p class="text-xs mt-1" style="color: var(--text-muted);">
              Bot: <span style="color: var(--text-main);">{escalation_status_label(conv.escalation_status) || "—"}</span>
              <%= if @crm_entry.escalation_status do %>
                <span
                  class="ml-2 px-2 py-0.5 rounded text-[10px] font-semibold"
                  style="background: #fef3c7; color: #92400e;"
                >
                  Anulado por operador
                </span>
              <% end %>
            </p>
          </div>

          <%!-- Axis 4: engagement_health (stuck-signal) --%>
          <div>
            <label
              for="conv_crm_engagement_health"
              class="block text-xs font-medium mb-1"
              style="color: var(--text-muted);"
            >
              Salud del Engagement
            </label>
            <select
              id="conv_crm_engagement_health"
              name="engagement_health"
              onchange="this.form.submit()"
              class="w-full rounded-md border px-3 py-2 text-sm"
              style={"background: var(--bg-surface); border-color: #{if @crm_entry.engagement_health, do: "#f59e0b", else: "var(--border-subtle)"}; color: var(--text-main);"}
            >
              <option value="" selected={is_nil(@crm_entry.engagement_health)}>
                — usar valor del bot —
              </option>
              <%= for {label, value} <- @crm_engagement_health_options do %>
                <option value={value} selected={@crm_entry.engagement_health == value}>
                  {label}
                </option>
              <% end %>
            </select>
            <p class="text-xs mt-1" style="color: var(--text-muted);">
              Bot: <span style="color: var(--text-main);">{engagement_health_label(conv.engagement_health) || "—"}</span>
              <%= if @crm_entry.engagement_health do %>
                <span
                  class="ml-2 px-2 py-0.5 rounded text-[10px] font-semibold"
                  style="background: #fef3c7; color: #92400e;"
                >
                  Anulado por operador
                </span>
              <% end %>
            </p>
          </div>

          <p class="text-xs" style="color: var(--text-muted);">
            Se guarda automáticamente al cambiar.
          </p>
        </.form>
      </div>

      <%!-- Conversation Details --%>
      <div class="hd-card p-5">
        <h3 class="text-sm font-semibold uppercase mb-3" style="color: var(--text-muted);">
          Detalles
        </h3>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between">
            <span style="color: var(--text-muted);">Estatus</span>
            <span style="color: var(--text-main);">
              {conv.status |> to_string() |> String.capitalize()}
            </span>
          </div>
          <div class="flex justify-between">
            <span style="color: var(--text-muted);">Etapa del Funnel (Bot)</span>
            <span style="color: var(--text-main);">
              {funnel_stage_label(conv.funnel_stage)}
            </span>
          </div>
          <div class="flex justify-between">
            <span style="color: var(--text-muted);">Califica</span>
            <span style="color: var(--text-main);">
              {cond do
                conv.qualifies == true -> "Sí"
                conv.qualifies == false -> "No"
                true -> "---"
              end}
            </span>
          </div>
          <%= if conv.recommended_modalidad do %>
            <div class="flex justify-between">
              <span style="color: var(--text-muted);">Modalidad Recomendada</span>
              <span style="color: var(--text-main);">{conv.recommended_modalidad}</span>
            </div>
          <% end %>
          <div class="flex justify-between">
            <span style="color: var(--text-muted);">Agente Recomendado</span>
            <span style="color: var(--text-main);">
              {if conv.agent_recommended, do: "Sí", else: "No"}
            </span>
          </div>
          <%= if conv.agent_declined_by_customer do %>
            <div class="flex justify-between">
              <span style="color: var(--text-muted);">Cliente rechazó al agente</span>
              <span style="color: #dc2626;">Sí</span>
            </div>
          <% end %>
          <%= if conv.resolved_without_agent do %>
            <div class="flex justify-between">
              <span style="color: var(--text-muted);">Resuelto sin agente</span>
              <span style="color: var(--accent);">Sí</span>
            </div>
          <% end %>
          <div class="flex justify-between">
            <span style="color: var(--text-muted);">Iniciada</span>
            <span style="color: var(--text-main);">{fmt_datetime(conv.created_at) || "---"}</span>
          </div>
          <div class="flex justify-between">
            <span style="color: var(--text-muted);">Último Mensaje</span>
            <span style="color: var(--text-main);">
              {fmt_datetime(conv.last_message_at) || "---"}
            </span>
          </div>
        </div>
      </div>

      <%!-- Linked Consultations --%>
      <div class="hd-card p-5">
        <h3 class="text-sm font-semibold uppercase mb-3" style="color: var(--text-muted);">
          Consultas
        </h3>
        <%= if Enum.empty?(conv.consultations) do %>
          <div class="text-sm" style="color: var(--text-muted);">
            Sin consultas desde esta conversación.
          </div>
        <% else %>
          <div class="space-y-2">
            <%= for cs <- conv.consultations do %>
              <.link
                navigate={dp(@domain_path_prefix, "/consultations/#{cs.id}")}
                class="block p-3 rounded-lg hover:bg-[rgba(31,59,106,0.04)] no-underline"
                style="border: 1px solid var(--border-subtle);"
              >
                <div class="flex items-center justify-between">
                  <span class={"hd-badge hd-badge--#{cs.status}"}>
                    {cs.status |> to_string() |> String.replace("_", " ") |> String.capitalize()}
                  </span>
                  <span class="text-xs" style="color: var(--text-muted);">
                    {fmt_date(cs.assigned_at) || "---"}
                  </span>
                </div>
                <%= if cs.payment_status do %>
                  <div class="text-xs mt-1" style="color: var(--text-muted);">
                    Pago: {cs.payment_status |> String.capitalize()}
                    {if cs.payment_amount,
                      do: " — $#{:erlang.float_to_binary(cs.payment_amount, decimals: 2)}",
                      else: ""}
                  </div>
                <% end %>
              </.link>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
