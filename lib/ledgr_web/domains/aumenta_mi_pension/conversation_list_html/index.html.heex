<div class="hd-page">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold" style="color: var(--text-main);">Conversaciones</h1>
  </div>

  <%!-- Filters --%>
  <div class="hd-card p-4 mb-6">
    <form method="get" action={dp(@domain_path_prefix, "/conversations")} class="flex flex-wrap gap-3 items-end">
      <div class="flex-1 min-w-[140px]">
        <label class="block text-xs font-medium mb-1" style="color: var(--text-muted);">Estatus</label>
        <select name="status" class="w-full rounded-md border px-3 py-2 text-sm" style="background: var(--bg-surface); border-color: var(--border-subtle); color: var(--text-main);">
          <option value="">Todos</option>
          <option value="active" selected={@current_status == "active"}>Activa</option>
          <option value="closed" selected={@current_status == "closed"}>Cerrada</option>
        </select>
      </div>
      <div class="flex-1 min-w-[180px]">
        <label class="block text-xs font-medium mb-1" style="color: var(--text-muted);">Etapa del Funnel</label>
        <select name="funnel_stage" class="w-full rounded-md border px-3 py-2 text-sm" style="background: var(--bg-surface); border-color: var(--border-subtle); color: var(--text-main);">
          <option value="">Todas</option>
          <option value="greeting" selected={@current_funnel_stage == "greeting"}>Saludo</option>
          <option value="data_collection" selected={@current_funnel_stage == "data_collection"}>Recolección de Datos</option>
          <option value="qualification" selected={@current_funnel_stage == "qualification"}>Calificación</option>
          <option value="simulation_sent" selected={@current_funnel_stage == "simulation_sent"}>Simulación Enviada</option>
          <option value="agent_recommended" selected={@current_funnel_stage == "agent_recommended"}>Agente Recomendado</option>
          <option value="consultation_active" selected={@current_funnel_stage == "consultation_active"}>Consulta Activa</option>
          <option value="completed" selected={@current_funnel_stage == "completed"}>Completada</option>
        </select>
      </div>
      <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-medium mb-1" style="color: var(--text-muted);">Búsqueda</label>
        <input type="text" name="search" value={@current_search} placeholder="Cliente o teléfono..."
          class="w-full rounded-md border px-3 py-2 text-sm"
          style="background: var(--bg-surface); border-color: var(--border-subtle); color: var(--text-main);" />
      </div>
      <button type="submit" class="hd-btn-secondary">Filtrar</button>
    </form>
  </div>

  <%!-- Conversations Table --%>
  <div class="hd-card overflow-hidden">
    <div class="overflow-x-auto">
      <table class="hd-table w-full">
        <thead>
          <tr>
            <th class="text-left p-3 text-xs font-medium uppercase" style="color: var(--text-muted);">Cliente</th>
            <th class="text-left p-3 text-xs font-medium uppercase" style="color: var(--text-muted);">Estatus</th>
            <th class="text-left p-3 text-xs font-medium uppercase" style="color: var(--text-muted);">Etapa</th>
            <th class="text-center p-3 text-xs font-medium uppercase" style="color: var(--text-muted);">Califica</th>
            <th class="text-center p-3 text-xs font-medium uppercase" style="color: var(--text-muted);">Consultas</th>
            <th class="text-left p-3 text-xs font-medium uppercase" style="color: var(--text-muted);">Iniciada</th>
            <th class="text-left p-3 text-xs font-medium uppercase" style="color: var(--text-muted);">Último Mensaje</th>
            <th class="text-right p-3 text-xs font-medium uppercase" style="color: var(--text-muted);">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <%= if Enum.empty?(@conversations) do %>
            <tr>
              <td colspan="8" class="p-8 text-center" style="color: var(--text-muted);">
                Sin conversaciones.
              </td>
            </tr>
          <% else %>
            <%= for conv <- @conversations do %>
              <tr class="border-t cursor-pointer hover:bg-[rgba(31,59,106,0.04)]"
                style="border-color: var(--border-subtle);"
                onclick={"window.location='#{dp(@domain_path_prefix, "/conversations/#{conv.id}")}';"}>
                <td class="p-3">
                  <div class="text-sm font-medium" style="color: var(--text-main);">
                    <%= if conv.customer, do: (conv.customer.full_name || conv.customer.display_name || "Desconocido"), else: "Desconocido" %>
                  </div>
                  <div class="text-xs" style="color: var(--text-muted);">
                    <%= if conv.customer, do: conv.customer.phone, else: "" %>
                  </div>
                </td>
                <td class="p-3">
                  <%
                    status_badge = case conv.status do
                      "active" -> "in_progress"
                      "closed" -> "completed"
                      _ -> "pending"
                    end
                  %>
                  <span class={"hd-badge hd-badge--#{status_badge}"}><%= conv.status |> to_string() |> String.capitalize() %></span>
                </td>
                <td class="p-3">
                  <span class="text-sm" style="color: var(--text-main);"><%= conv.funnel_stage |> to_string() |> String.replace("_", " ") |> String.capitalize() %></span>
                </td>
                <td class="p-3 text-center">
                  <%= cond do
                    conv.qualifies == true -> Phoenix.HTML.raw(~s(<span style="color: #16a34a;">Sí</span>))
                    conv.qualifies == false -> Phoenix.HTML.raw(~s(<span style="color: #dc2626;">No</span>))
                    true -> Phoenix.HTML.raw(~s|<span style="color: var(--text-muted);">-</span>|)
                  end %>
                </td>
                <td class="p-3 text-center">
                  <span class="text-sm font-medium" style="color: var(--text-main);"><%= length(conv.consultations) %></span>
                </td>
                <td class="p-3 text-sm" style="color: var(--text-muted);">
                  <%= if conv.created_at, do: Calendar.strftime(conv.created_at, "%b %d, %Y %I:%M %p"), else: "---" %>
                </td>
                <td class="p-3 text-sm" style="color: var(--text-muted);">
                  <%= if conv.last_message_at, do: Calendar.strftime(conv.last_message_at, "%b %d, %I:%M %p"), else: "---" %>
                </td>
                <td class="p-3 text-right">
                  <.link navigate={dp(@domain_path_prefix, "/conversations/#{conv.id}")} class="text-sm font-medium" style="color: var(--accent);">
                    Ver
                  </.link>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
